{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=EMK.Save.DB;Integrated Security=True"
  },
  "AppSettings": {
    "Secret": "EMKSave_SuperSecret_JWT_Key_32chars!!"
  },
  "Plaid": {
    "ClientId": "",
    "Secret": "",
    "Environment": "Sandbox",
    "WebhookUrl": ""
  },
  "Encryption": {
    "PlaidTokenKey": ""
  },
  "AllowedOrigins": "http://localhost:5173",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
