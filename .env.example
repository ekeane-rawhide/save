# Copy to .env and fill in real values before running `docker compose up`.
# docker compose auto-loads .env from the repo root — never commit the real .env file.

# SQL Server "sa" password — must satisfy SQL Server's complexity policy
# (8+ chars, upper+lower+digit+symbol).
SA_PASSWORD=

# JWT signing key — 32+ characters. Generate one with:
#   openssl rand -base64 32
JWT_SECRET=

# Plaid sandbox (or production) credentials from https://dashboard.plaid.com
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENVIRONMENT=Sandbox
# Public HTTPS URL Plaid can reach to deliver webhooks — leave blank if not exposing one yet.
PLAID_WEBHOOK_URL=

# AES-256 key (base64) for encrypting Plaid access tokens at rest. Generate one with:
#   openssl rand -base64 32
PLAID_TOKEN_ENCRYPTION_KEY=

# Web Push (VAPID) key pair — generate with the `web-push` CLI (`npx web-push generate-vapid-keys`)
# or any ECDSA P-256 keypair. The public key must match EMK.Save.PWA's VITE_VAPID_PUBLIC_KEY exactly.
WEBPUSH_SUBJECT=mailto:support@example.com
WEBPUSH_PUBLIC_KEY=
WEBPUSH_PRIVATE_KEY=
