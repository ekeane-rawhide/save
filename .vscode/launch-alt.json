{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "npm: dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "VITE.*ready in.*ms",
        "uriFormat": "http://localhost:5173",
        "action": "openExternally"
      }
    }
  ]
}
