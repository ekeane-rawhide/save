{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "open browser",
      "command": "powershell",
      "args": ["-Command", "Start-Sleep -Seconds 3; start http://localhost:5173"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*$",
          "endsPattern": "^.*$"
        }
      }
    }
  ]
}
